PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX_NAME=namma-aria
GROQ_API_KEY=your_groq_key
TAVILY_API_KEY=your_tavily_key

# LLM_PROVIDER controls which LLM is used for the copilot chat (Q&A only).
# The PM workflow pipeline (KPI, RCA, prioritization, PRD) runs without any LLM.
#
# Options:
#   groq    — Groq llama-3.1-8b-instant (default; free tier has 6K TPM limit)
#   ollama  — Local Ollama (free, unlimited; run: ollama pull llama3.2)
#   gemini  — Google Gemini 1.5 Flash (free tier, 1M token context)
#   openai  — OpenAI GPT-4o-mini (cheap)
LLM_PROVIDER=groq

# Required only if LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2

# Required only if LLM_PROVIDER=gemini
# GOOGLE_API_KEY=your_google_api_key
# GEMINI_MODEL=gemini-1.5-flash

# Required only if LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key
# OPENAI_MODEL=gpt-4o-mini
